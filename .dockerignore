# Keep the build context small and secret-free. Everything here is
# excluded from ``COPY . .`` — pared-down context = faster builds and
# no risk of baking a local ``.env`` into the image.

# Local environment + credentials
.env
.env.*
!.env.example
*.pem
*.key
id_rsa*

# VCS + editor junk
.git
.github
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Python caches / build output
__pycache__
*.pyc
*.pyo
*.pyd
.Python
*.egg-info
dist
build
.mypy_cache
.pytest_cache
.ruff_cache
htmlcov
.coverage
.tox

# Virtualenvs (we re-create ours via poetry install)
.venv
venv
env

# Local data (never bake per-user state into a shared image)
data
*.sqlite
*.db
*.db-journal
*.db-wal
*.db-shm
logs

# Developer / docs tooling
docs
tests
Makefile
*.md
!README.md
CHANGELOG.md
SECURITY.md

# Node / JS (if ever pulled in transitively)
node_modules

# OS
Thumbs.db
